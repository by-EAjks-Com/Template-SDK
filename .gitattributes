# Default Attributes
* text=auto

# Attributes for Source Files
*.h      text diff=cpp
*.hh     text diff=cpp
*.hpp    text diff=cpp
*.hxx    text diff=cpp
*.h++    text diff=cpp
*.c      text diff=cpp
*.cc     text diff=cpp
*.cpp    text diff=cpp
*.cxx    text diff=cpp
*.c++    text diff=cpp
*.cpi    text diff=cpp

# Attributes for Precompiled Headers
*.gch    binary
*.pch    binary

# Attributes for Compiled Object Files
*.o      binary
*.obj    binary
*.lo     binary
*.slo    binary

# Attributes for Compiled Static Libraries
*.a      binary
*.la     binary
*.lai    binary
*.lib    binary

# Attributes for Compiled Shared Libraries
*.so     binary
*.dylib  binary
*.dll    binary

# Attributes for Compiled Executables
*.exe    binary
*.out    binary
*.app    binary

# Attributes for Python Sources
*.pxd    text diff=python
*.py     text diff=python
*.py3    text diff=python
*.pyi    text diff=python
*.pyw    text diff=python
*.pyx    text diff=python
*.pyz    text diff=python

# Attributes for Python Binaries
*.db     binary
*.p      binary
*.pkl    binary
*.pickle binary
*.pyc    binary export-ignore
*.pyo    binary export-ignore
*.pyd    binary

# Attributes for Jupyter Notebooks
*.ipynb  text eol=lf

# Attributes for Bash Scripts
*.bash   text eol=lf diff=bash
*.sh     text eol=lf diff=bash

# Attributes for BATCH/CMD Scripts
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Attributes for PowerShell Scripts
*.ps1    text eol=crlf
*.ps1x   text eol=crlf
*.psm1   text eol=crlf
*.psd1   text eol=crlf
*.ps1xml text eol=crlf
*.pssc   text eol=crlf
*.psrc   text eol=crlf
*.cdxml  text eol=crlf

# Attributes for TCL/TK Scripts
*.tcl    text
*.tk     text

# Attributes for Configuration Files
*.json   text
*.xml    text
*.yaml   text

# Attributes for Documents
*.md     text diff=markdown
*.jpg    binary
*.jpeg   binary
*.png    binary
*.tif    binary
*.tiff   binary
*.doc    binary
*.docx   binary
*.ppt    binary
*.pptx   binary
*.vsd    binary
*.vsdx   binary
*.xls    binary
*.xlsx   binary
*.pdf    binary

# Attributes for Archives
*.zip    binary
*.tar    binary
*.gz     binary
*.tgz    binary
*.bz     binary
*.tbz    binary
